<!DOCTYPE html>
<html lang="zh-CN">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title><!-- COHORT_TITLE --></title>
<style>
  :root {
    --bg: #0a0f1e;
    --bg-2: #111835;
    --card: rgba(255,255,255,0.04);
    --card-hover: rgba(255,255,255,0.08);
    --text: #e8ecf5;
    --muted: #8b94b3;
    --line: rgba(255,255,255,0.08);
    --accent: #5eead4;
    --gold: #fbbf24;
    --rose: #fb7185;
    --A: #60a5fa;
    --B: #34d399;
    --E: #f97316;
    --F: #c084fc;
  }
  * { box-sizing: border-box; }
  html, body {
    margin: 0; padding: 0;
    background: var(--bg);
    color: var(--text);
    font-family: -apple-system, "PingFang SC", "Microsoft YaHei", "Helvetica Neue", Arial, sans-serif;
    line-height: 1.65;
    -webkit-font-smoothing: antialiased;
  }
  body {
    background:
      radial-gradient(1200px 600px at 10% -10%, rgba(96,165,250,0.18), transparent 60%),
      radial-gradient(1000px 500px at 90% -10%, rgba(192,132,252,0.16), transparent 55%),
      radial-gradient(1000px 600px at 50% 110%, rgba(52,211,153,0.12), transparent 60%),
      var(--bg);
    min-height: 100vh;
  }
  header.hero {
    padding: 60px 6vw 30px;
    text-align: center;
    border-bottom: 1px solid var(--line);
  }
  .badge {
    display: inline-block;
    padding: 4px 14px;
    border-radius: 999px;
    background: rgba(94, 234, 212, 0.12);
    color: var(--accent);
    font-size: 13px;
    letter-spacing: 1px;
    border: 1px solid rgba(94, 234, 212, 0.3);
    margin-bottom: 16px;
  }
  h1 {
    font-size: clamp(28px, 4vw, 48px);
    font-weight: 800;
    margin: 0 0 12px;
    background: linear-gradient(135deg, #fff 0%, #93c5fd 50%, #c4b5fd 100%);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    letter-spacing: -0.5px;
  }
  .subtitle {
    color: var(--muted);
    font-size: clamp(14px, 1.6vw, 17px);
    max-width: 760px;
    margin: 0 auto;
  }
  .stat-row {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 16px;
    max-width: 1100px;
    margin: 36px auto 0;
  }
  .stat {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 16px 14px;
    backdrop-filter: blur(8px);
  }
  .stat .num {
    font-size: 28px;
    font-weight: 700;
    background: linear-gradient(135deg, var(--accent), #93c5fd);
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .stat .lbl { font-size: 13px; color: var(--muted); margin-top: 2px; }
  nav.zones {
    position: sticky; top: 0; z-index: 50;
    backdrop-filter: blur(14px);
    background: rgba(10, 15, 30, 0.78);
    border-bottom: 1px solid var(--line);
    padding: 14px 6vw;
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    justify-content: center;
  }
  nav.zones a {
    color: var(--text);
    text-decoration: none;
    font-size: 14px;
    padding: 8px 16px;
    border-radius: 999px;
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--line);
    transition: all .2s;
  }
  nav.zones a:hover { background: rgba(255,255,255,0.12); transform: translateY(-1px); }
  nav.zones .pill-A:hover { border-color: var(--A); color: var(--A); }
  nav.zones .pill-B:hover { border-color: var(--B); color: var(--B); }
  nav.zones .pill-E:hover { border-color: var(--E); color: var(--E); }
  nav.zones .pill-F:hover { border-color: var(--F); color: var(--F); }
  main { max-width: 1400px; margin: 0 auto; padding: 24px 4vw 80px; }
  section.zone { margin-top: 50px; scroll-margin-top: 72px; }
  .zone-head {
    display: flex; align-items: baseline; gap: 16px; flex-wrap: wrap;
    border-left: 4px solid;
    padding-left: 16px;
    margin-bottom: 22px;
  }
  .zone-head .zid { font-size: clamp(22px, 3vw, 30px); font-weight: 800; }
  .zone-head .ztheme { color: var(--muted); font-size: 16px; }
  .zone-head .zcount {
    background: rgba(255,255,255,0.07);
    border-radius: 999px;
    padding: 3px 12px;
    font-size: 13px;
    color: var(--muted);
  }
  #zone-A .zone-head { border-color: var(--A); }
  #zone-B .zone-head { border-color: var(--B); }
  #zone-E .zone-head { border-color: var(--E); }
  #zone-F .zone-head { border-color: var(--F); }
  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(360px, 1fr));
    gap: 18px;
  }
  .card {
    position: relative;
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 22px;
    transition: all .25s ease;
    backdrop-filter: blur(6px);
    display: flex;
    flex-direction: column;
  }
  .card:hover { background: var(--card-hover); transform: translateY(-3px); border-color: rgba(255,255,255,0.18); }
  .card.star::after {
    content: "★ 重点项目";
    position: absolute; top: 14px; right: 14px;
    font-size: 11px; letter-spacing: 0.5px;
    background: linear-gradient(135deg, var(--gold), #fb923c);
    color: #1a1108; padding: 3px 9px; border-radius: 999px;
    font-weight: 600;
  }
  .card.double-star::after {
    content: "★★ 投资 TOP1";
    background: linear-gradient(135deg, #fb7185, #fbbf24);
    color: #1a0808; font-weight: 700;
  }
  .card-id {
    display: inline-block;
    font-size: 11px;
    letter-spacing: 1.5px;
    padding: 2px 8px;
    border-radius: 4px;
    background: rgba(255,255,255,0.06);
    color: var(--muted);
    margin-bottom: 12px;
    font-family: ui-monospace, SFMono-Regular, Menlo, monospace;
  }
  #zone-A .card-id { color: var(--A); background: rgba(96,165,250,0.12); }
  #zone-B .card-id { color: var(--B); background: rgba(52,211,153,0.12); }
  #zone-E .card-id { color: var(--E); background: rgba(249,115,22,0.12); }
  #zone-F .card-id { color: var(--F); background: rgba(192,132,252,0.12); }
  .card h3 {
    font-size: 19px;
    margin: 0 0 6px;
    color: #fff;
    font-weight: 700;
    letter-spacing: -0.2px;
  }
  .card .tagline {
    font-size: 13.5px;
    color: var(--accent);
    margin-bottom: 14px;
    line-height: 1.5;
  }
  .field {
    margin: 10px 0;
    font-size: 13.5px;
    line-height: 1.65;
  }
  .field b {
    display: inline-block;
    color: var(--muted);
    font-weight: 500;
    margin-right: 6px;
    min-width: 56px;
  }
  .founder-box {
    background: linear-gradient(135deg, rgba(251,191,36,0.10), rgba(251,113,133,0.06));
    border: 1px solid rgba(251,191,36,0.25);
    border-radius: 10px;
    padding: 12px 14px;
    margin: 12px 0;
  }
  .founder-box .lbl {
    font-size: 11px;
    letter-spacing: 1.5px;
    color: var(--gold);
    font-weight: 600;
    margin-bottom: 4px;
  }
  .founder-box .name {
    font-size: 15px;
    color: #fff;
    font-weight: 600;
    margin-bottom: 6px;
  }
  .founder-box .bio {
    font-size: 12.5px;
    color: rgba(232, 236, 245, 0.82);
    line-height: 1.6;
  }
  .funding {
    background: rgba(94, 234, 212, 0.08);
    border-left: 3px solid var(--accent);
    padding: 8px 12px;
    border-radius: 4px;
    font-size: 12.5px;
    margin: 10px 0;
    color: rgba(232, 236, 245, 0.92);
  }
  .links {
    display: flex; gap: 8px; flex-wrap: wrap;
    margin-top: 14px;
    padding-top: 14px;
    border-top: 1px dashed var(--line);
  }
  .links a {
    display: inline-flex;
    align-items: center; gap: 5px;
    font-size: 12px;
    padding: 5px 11px;
    border-radius: 6px;
    text-decoration: none;
    transition: all .2s;
  }
  .links a.site {
    background: rgba(94,234,212,0.15);
    color: var(--accent);
    border: 1px solid rgba(94,234,212,0.25);
  }
  .links a.repo {
    background: rgba(251,191,36,0.13);
    color: var(--gold);
    border: 1px solid rgba(251,191,36,0.25);
  }
  .links a:hover { transform: translateY(-1px); filter: brightness(1.15); }
  .links a::before {
    content: ""; width: 6px; height: 6px; border-radius: 50%;
    background: currentColor;
  }
  .meta-row {
    display: flex; flex-wrap: wrap; gap: 8px;
    font-size: 11.5px;
    margin-top: 10px;
  }
  .chip {
    background: rgba(255,255,255,0.05);
    border: 1px solid var(--line);
    color: var(--muted);
    padding: 3px 9px; border-radius: 999px;
  }
  .highlight {
    color: rgba(232, 236, 245, 0.78);
    font-size: 12.5px;
    line-height: 1.6;
    margin-top: 8px;
    padding: 8px 0 0;
    border-top: 1px dotted var(--line);
  }
  footer {
    text-align: center;
    padding: 40px 6vw 30px;
    color: var(--muted);
    font-size: 13px;
    border-top: 1px solid var(--line);
    margin-top: 60px;
  }
  footer a { color: var(--accent); text-decoration: none; }

  @media (max-width: 720px) {
    .grid { grid-template-columns: 1fr; }
    nav.zones { gap: 6px; padding: 10px 4vw; }
    nav.zones a { padding: 6px 12px; font-size: 13px; }
  }
</style>
</head>
<body>

<header class="hero">
  <div class="badge"><!-- COHORT_BADGE --></div>
  <h1><!-- COHORT_H1 --></h1>
  <p class="subtitle">2026 春季创业营 56 个录取项目深度调研报告 · 创始人简历 / 官网 / 开源仓库 / 融资详情 · v4.0 一手补全（微信文章 + 项目卡）</p>
  <div class="stat-row">
    <div class="stat"><div class="num">56</div><div class="lbl">录取项目</div></div>
    <div class="stat"><div class="num">43<span style="font-size:18px">%</span></div><div class="lbl">海外背景</div></div>
    <div class="stat"><div class="num">45<span style="font-size:18px">%</span></div><div class="lbl">Researcher Founder</div></div>
    <div class="stat"><div class="num">62<span style="font-size:18px">%</span></div><div class="lbl">硕士及以上学历</div></div>
    <div class="stat"><div class="num">22</div><div class="lbl">出海项目</div></div>
    <div class="stat"><div class="num">1<span style="font-size:18px">%</span></div><div class="lbl">录取率</div></div>
  </div>
  <!-- KEYNOTE_CALLOUT: removed by template. Re-inserted by build_panoramic.py if meta.keynote present. -->
</header>

<nav class="zones">
  <a class="pill-A" href="#zone-A">A 区 · 前沿科技</a>
  <a class="pill-B" href="#zone-B">B 区 · 具身与硬件</a>
  <a class="pill-E" href="#zone-E">E 区 · Agent toB</a>
  <a class="pill-F" href="#zone-F">F 区 · Agent toC</a>
  <a href="#top-picks" style="border-color: var(--gold); color: var(--gold);">★ 重点 TOP10</a>
  <a href="dd.html" style="border-color: var(--rose); color: var(--rose);">🔍 DD 尽职调查表 →</a>
  <a href="https://github.com/zhanglunet/demo-day-dossier" target="_blank" rel="noopener" style="border-color: var(--muted); color: var(--muted);">⌥ GitHub 源码</a>
</nav>

<main id="content"></main>

<footer>
  数据源：奇绩创坛官方项目卡 · 路演现场照 · 公开网络调研 ｜
  报告版本 v3.0 · 2026-06-07 ｜
  仅供学习研究参考<br>
  源码：<a href="https://github.com/zhanglunet/demo-day-dossier" target="_blank" rel="noopener" style="color:var(--accent);">github.com/zhanglunet/demo-day-dossier</a><br><br>
  Built for an open ecosystem of founders, investors, and tinkerers.
</footer>

<script>
const DATA = /*__JSON_PLACEHOLDER__*/{};

function el(tag, cls, html) {
  const e = document.createElement(tag);
  if (cls) e.className = cls;
  if (html !== undefined) e.innerHTML = html;
  return e;
}
function esc(s) {
  if (!s) return '';
  return s.replace(/[&<>"']/g, m => ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[m]));
}
function projectCard(p) {
  const card = el('div', 'card' + (p.star ? ' star' : '') + (p.double_star ? ' double-star' : ''));
  card.innerHTML = `
    <span class="card-id">${p.id}</span>
    <h3>${esc(p.name)}</h3>
    <div class="tagline">${esc(p.tagline || '')}</div>
    ${p.direction ? `<div class="field"><b>方向</b>${esc(p.direction)}</div>` : ''}
    ${p.company ? `<div class="field"><b>主体</b>${esc(p.company)}</div>` : ''}
    ${p.founder ? `
      <div class="founder-box">
        <div class="lbl">FOUNDER · 创始人</div>
        <div class="name">${esc(p.founder)}</div>
        ${p.team ? `<div class="bio">${esc(p.team)}</div>` : ''}
      </div>` : ''}
    ${p.funding ? `<div class="funding">💰 ${esc(p.funding)}</div>` : ''}
    ${p.benchmarks ? `<div class="field" style="font-size:12px;color:var(--muted)"><b>对标</b>${esc(p.benchmarks)}</div>` : ''}
    ${p.highlight ? `<div class="highlight">✨ ${esc(p.highlight)}</div>` : ''}
    ${(p.site || p.github) ? `
      <div class="links">
        ${p.site ? `<a class="site" target="_blank" href="${esc(p.site)}">官网</a>` : ''}
        ${p.github ? `<a class="repo" target="_blank" href="${esc(p.github)}">GitHub / Repo</a>` : ''}
      </div>` : ''}
  `;
  return card;
}

const content = document.getElementById('content');

// Top picks
const allProjects = DATA.zones.flatMap(z => z.projects.map(p => ({...p, zone: z.zone})));
const topPicks = allProjects.filter(p => p.double_star || p.star);

const topSection = el('section', 'zone');
topSection.id = 'top-picks';
topSection.innerHTML = `
  <div class="zone-head" style="border-color: var(--gold)">
    <span class="zid" style="color: var(--gold)">★ 重点关注</span>
    <span class="ztheme">高潜投资价值项目（含创始人/团队/融资亮点）</span>
    <span class="zcount">${topPicks.length} 项</span>
  </div>
`;
const topGrid = el('div', 'grid');
topPicks.forEach(p => topGrid.appendChild(projectCard(p)));
topSection.appendChild(topGrid);
content.appendChild(topSection);

// Zones
DATA.zones.forEach(z => {
  const sec = el('section', 'zone');
  sec.id = 'zone-' + z.zone[0];
  sec.innerHTML = `
    <div class="zone-head">
      <span class="zid">${z.zone}</span>
      <span class="ztheme">${esc(z.theme)}</span>
      <span class="zcount">${z.count} 项</span>
    </div>
  `;
  const grid = el('div', 'grid');
  z.projects.forEach(p => grid.appendChild(projectCard(p)));
  sec.appendChild(grid);
  content.appendChild(sec);
});
</script>
</body>
</html>
