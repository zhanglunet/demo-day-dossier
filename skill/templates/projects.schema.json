{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "demo-day-dossier project dataset",
  "type": "object",
  "required": ["meta", "zones"],
  "properties": {
    "meta": {
      "type": "object",
      "properties": {
        "title":   { "type": "string" },
        "subtitle":{ "type": "string" },
        "date":    { "type": "string", "format": "date" },
        "version": { "type": "string" },
        "source":  { "type": "string" },
        "cohort":  { "type": "string" },
        "lu_qi_keynote": { "type": "string", "description": "Optional cohort keynote quote" },
        "stats": {
          "type": "object",
          "properties": {
            "total": { "type": "integer", "minimum": 1 },
            "recruitment_rate": { "type": "string" },
            "researcher_founder_pct": { "type": "integer" },
            "overseas_pct": { "type": "integer" },
            "by_industry": { "type": "object", "additionalProperties": { "type": "integer" } },
            "by_track":    { "type": "object", "additionalProperties": { "type": "integer" } }
          }
        }
      }
    },
    "zones": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["zone", "theme", "count", "projects"],
        "properties": {
          "zone":  { "type": "string", "description": "e.g. 'A区' or 'Track 1'" },
          "theme": { "type": "string", "description": "Human-readable theme" },
          "count": { "type": "integer", "minimum": 0 },
          "color": { "type": "string", "description": "Hex color for zone pill" },
          "projects": {
            "type": "array",
            "items": { "$ref": "#/definitions/project" }
          }
        }
      }
    }
  },
  "definitions": {
    "project": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id":         { "type": "string", "description": "Zone letter + 2-digit number, e.g. 'A01'" },
        "name":       { "type": "string" },
        "tagline":    { "type": "string", "description": "一句话定位 ≤30 chars" },
        "direction":  { "type": "string", "description": "Product/technical direction" },
        "founder":    { "type": "string", "description": "Primary founder + role; surfaced in UI gold box" },
        "team":       { "type": "string", "description": "Full team paragraph: founders + key roles" },
        "company":    { "type": "string", "description": "Legal entity name + region" },
        "site":       { "type": "string", "format": "uri" },
        "github":     { "type": "string", "format": "uri" },
        "funding":    { "type": "string", "description": "Round + amount + investors if known" },
        "benchmarks": { "type": "string", "description": "Comparable products separated by 顿号 or commas" },
        "highlight":  { "type": "string", "description": "Standout proof / PR moment" },
        "star":       { "type": "boolean", "description": "⭐ Recommended (>= top 30%)" },
        "double_star":{ "type": "boolean", "description": "⭐⭐ Top 1-3 cohort flagship" }
      }
    }
  }
}
